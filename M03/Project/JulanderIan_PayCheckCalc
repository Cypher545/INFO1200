# Display app name
print("Ian Julander's Pay Check Calculator App")
print()

# get user input for hours worked
hoursWorked = float(input("Hours worked: "))

# get user input for pay rate
payRate = float(input("Hourly pay rate: "))

print()

# calculate gross pay
grossPay = hoursWorked * payRate

# display gross pay
print("Gross pay: $" + str(round(grossPay, 2)))

# create variable for tax rate
taxRate = 18

# display tax rate
print("Tax rate: " + str(taxRate) + "%")

# create variable for tax amount and calculate
taxAmount = grossPay * (taxRate / 100)

# display tax amount
print("Tax amount: $" + str(round(taxAmount, 2)))

# create variable for take home pay and calculate
takeHomePay = grossPay - taxAmount

# display take home pay
print("Take home pay: $" + str(round(takeHomePay, 2)))