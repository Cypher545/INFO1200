# display app name
print("Ian Julander's Tip Calculator App")
print()

# get user input and store in variables
costOfMeal = float(input("Cost of meal: $"))
# get user input for tip percentage
tipPercentage = float(input("Tip percentage: "))

print()

# create new variable for tip amount and calculate
tipAmount = costOfMeal * (tipPercentage / 100)

# display tip amount
print("Tip amount: $" + str(round(tipAmount, 2)))

# calculate and display total cost
print("Total amount: $" + str(round(costOfMeal + tipAmount, 2)))